# Disable directory browsing for security reasons
Options All -Indexes

# Protect the .htaccess file from direct public access
<Files .htaccess>
    order allow,deny
    deny from all
</Files>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ==========================================
    # UNIVERSAL ROUTING (XAMPP + Render Cloud)
    # ==========================================
    # Skip rewrite for real files and directories.
    RewriteCond %{REQUEST_FILENAME} -d [OR]
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # ==========================================
    # LOCAL DEVELOPMENT (XAMPP subdirectory)
    # ==========================================
    # When accessed via XAMPP subdirectory path, strip the base prefix
    # before handing off to Slim so Slim sees only the route segment.
    RewriteCond %{REQUEST_URI} ^/cpad-project/gamma-3/public(/.*)?$
    RewriteBase /cpad-project/gamma-3/public/
    RewriteRule ^ index.php [QSA,L]

    # ==========================================
    # PRODUCTION / ROOT-MOUNTED (Render Cloud)
    # ==========================================
    # When public/ is the document root (Render Docker), simply forward
    # every non-file, non-directory request to index.php.
    RewriteRule ^ index.php [QSA,L]

</IfModule>
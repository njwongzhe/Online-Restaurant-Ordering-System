# Disable directory browsing for security reasons
Options All -Indexes

# Protect the .htaccess file from direct public access
<Files .htaccess>
    order allow,deny
    deny from all
</Files>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ==========================================
    # 1. PRODUCTION ENVIRONMENT (Render Cloud)
    # ==========================================
    # If the request comes from a cloud proxy (Render uses X-Forwarded-Proto),
    # apply root-level rewrite rules and prevent internal 10-time redirection loop.
    RewriteCond %{HTTP:X-Forwarded-Proto} !^$
    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [QSA,L]


    # ==========================================
    # 2. LOCAL DEVELOPMENT ENVIRONMENT (XAMPP)
    # ==========================================
    # If it is a local request (No cloud proxy header present),
    # enforce the native RewriteBase to support XAMPP subdirectory alias routing.
    RewriteBase /cpad-project/gamma-3/
    RewriteCond %{HTTP:X-Forwarded-Proto} ^$
    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [QSA,L]

</IfModule>
# Disable directory browsing for security reasons
Options All -Indexes

# Protect the .htaccess file from direct public access
<Files .htaccess>
    order allow,deny
    deny from all
</Files>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ==========================================
    # 1. PRODUCTION ENVIRONMENT (Render Cloud)
    # ==========================================
    # If it is a cloud proxy environment, route the complete path cleanly.
    # The [L] flag will stop processing immediately and pass it to Slim.
    RewriteCond %{HTTP:X-Forwarded-Proto} !^$
    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    # 🎯 FORCE EXPLICIT ROUTING VIA RELATIVE PATH FOR CLOUD CONTAINER
    RewriteRule ^(.*)$ index.php [QSA,L]


    # ==========================================
    # 2. LOCAL DEVELOPMENT ENVIRONMENT (XAMPP)
    # ==========================================
    # If it is a local request, enforce native RewriteBase for XAMPP subdirectory layout.
    RewriteCond %{HTTP:X-Forwarded-Proto} ^$
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    
    # Apache aliases /cpad-project/gamma-3 directly to this public folder.
    # The browser URL does not include /public, so the RewriteBase should not either.
    RewriteBase /cpad-project/gamma-3/
    RewriteRule ^ index.php [QSA,L]

</IfModule>
